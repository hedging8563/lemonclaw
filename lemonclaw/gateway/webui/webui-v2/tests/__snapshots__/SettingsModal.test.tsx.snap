// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`operator settings editors > renders HTTP auth profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">HTTP Auth Profiles</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Store reusable header sets by profile name. Keep the masked value unchanged if you do not want to rotate an existing secret.</div></div><div style="margin-bottom:12px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;overflow:hidden;"><div style="display:flex;align-items:stretch;justify-content:space-between;gap:8px;"><button type="button" aria-expanded="false" style="flex:1;min-width:0px;display:flex;align-items:center;justify-content:space-between;gap:8px;padding:12px 16px;background:transparent;border:none;cursor:pointer;text-align:left;"><div style="display:flex;align-items:center;gap:8px;min-width:0px;"><span style="color:var(--text-primary);font-family:var(--font-mono);font-size:13px;font-weight:bold;overflow-wrap:anywhere;">support_api</span><span style="font-size:10px;padding:2px 6px;border-radius:3px;font-family:var(--font-mono);background:rgba(100,149,237,0.15);color:cornflowerblue;border:1px solid rgba(100,149,237,0.3);">2 headers</span></div><span style="color:var(--text-muted);font-size:12px;flex-shrink:0;">▼</span></button><button type="button" style="align-self:center;background:none;border:none;color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete profile" title="Delete profile">×</button></div></div><button type="button" style="width:100%;padding:10px;background:var(--bg-secondary);border:1px dashed var(--border);border-radius:6px;color:var(--text-muted);cursor:pointer;font-family:var(--font-mono);font-size:12px;">+ Add auth profile</button></div>"`;

exports[`operator settings editors > renders PostgreSQL profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">PostgreSQL Profiles</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Store read-only PostgreSQL connection profiles by name. Keep masked passwords unchanged unless you intentionally rotate them.</div></div><div style="margin-bottom:12px;"><div style="margin-bottom:12px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;overflow:hidden;"><div style="display:flex;align-items:stretch;justify-content:space-between;gap:8px;"><button type="button" aria-expanded="false" style="flex:1;min-width:0px;display:flex;align-items:center;justify-content:space-between;gap:8px;padding:12px 16px;background:transparent;border:none;cursor:pointer;text-align:left;"><div style="display:flex;align-items:center;gap:8px;min-width:0px;"><span style="color:var(--text-primary);font-family:var(--font-mono);font-size:13px;font-weight:bold;overflow-wrap:anywhere;">analytics_ro</span><span style="font-size:10px;padding:2px 6px;border-radius:3px;font-family:var(--font-mono);background:rgba(76,175,80,0.15);color:var(--success);border:1px solid rgba(76,175,80,0.3);">db.example.internal</span><span style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">analytics</span></div><span style="color:var(--text-muted);font-size:12px;flex-shrink:0;">▼</span></button><button type="button" style="align-self:center;background:none;border:none;color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete profile" title="Delete profile">×</button></div></div></div><div style="display:flex;gap:8px;flex-wrap:nowrap;"><label for="postgres-profile-name" style="position:absolute;width:1px;height:1px;padding:0px;margin:-1px;overflow:hidden;clip:rect(0, 0, 0, 0);white-space:nowrap;border:0px;">Profile name (for example: analytics_ro)</label><input id="postgres-profile-name" name="postgres_profile_name" aria-label="Profile name (for example: analytics_ro)" style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value placeholder="Profile name (for example: analytics_ro)"/><button type="button" style="padding:8px 16px;background:var(--accent);border:none;border-radius:4px;color:#fff;cursor:pointer;font-family:var(--font-mono);font-size:12px;white-space:nowrap;width:auto;">Add profile</button></div></div>"`;

exports[`operator settings editors > renders SQLite profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">SQLite Profiles</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Each profile maps a friendly name to one SQLite file path. The db tool uses these names instead of raw paths.</div></div><div style="margin-bottom:12px;"><div style="display:grid;grid-template-columns:minmax(140px, 0.8fr) minmax(0, 1.2fr) auto;gap:8px;align-items:start;margin-bottom:10px;"><div><label style="display:block;font-size:11px;color:var(--text-secondary);margin-bottom:4px;font-family:var(--font-mono);">Profile name</label><input style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value="local_cache" placeholder="Profile name (for example: local_cache)"/></div><div><label style="display:block;font-size:11px;color:var(--text-secondary);margin-bottom:4px;font-family:var(--font-mono);">SQLite file path</label><input style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value="/var/lib/lemonclaw/cache.db" placeholder="/var/lib/lemonclaw/app.db"/></div><div style="padding-top:22px;"><button type="button" style="align-self:center;background:none;border:1px solid var(--border);color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete profile" title="Delete profile">×</button></div></div></div><div style="display:flex;gap:8px;flex-wrap:nowrap;"><label for="sqlite-profile-name" style="position:absolute;width:1px;height:1px;padding:0px;margin:-1px;overflow:hidden;clip:rect(0, 0, 0, 0);white-space:nowrap;border:0px;">Profile name (for example: local_cache)</label><input id="sqlite-profile-name" name="sqlite_profile_name" aria-label="Profile name (for example: local_cache)" style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value placeholder="Profile name (for example: local_cache)"/><button type="button" style="padding:8px 16px;background:var(--accent);border:none;border-radius:4px;color:#fff;cursor:pointer;font-family:var(--font-mono);font-size:12px;white-space:nowrap;width:auto;">Add profile</button></div></div>"`;

exports[`operator settings editors > renders governance overview tab 1`] = `"<div style="display:flex;flex-direction:column;gap:16px;"><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));gap:12px;"><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Governance Status</div><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;"><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(45, 212, 191, 0.28);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);">Enabled</span><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(148, 163, 184, 0.24);background:rgba(148, 163, 184, 0.10);color:var(--text-muted);">Kill Switch Off</span></div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Autonomy Cap: <span style="color:var(--text-primary);font-family:var(--font-mono);">L1</span></div><div>Token TTL: <span style="color:var(--text-primary);font-family:var(--font-mono);">900s</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Capabilities</div><div style="font-family:var(--font-mono);font-size:18px;color:var(--accent);font-weight:bold;">12</div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Enabled: <span style="color:var(--text-primary);font-family:var(--font-mono);">11</span></div><div>Disabled: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Profiles</div><div style="font-family:var(--font-mono);font-size:18px;color:var(--accent);font-weight:bold;">2</div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Secret Profiles: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div><div>Sandbox Profiles: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Budget Defaults</div><div style="margin-top:2px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Task Budget: <span style="color:var(--text-primary);font-family:var(--font-mono);">$2.5</span></div><div>Platform Daily: <span style="color:var(--text-primary);font-family:var(--font-mono);">$50</span></div><div>Tenant Daily: <span style="color:var(--text-primary);font-family:var(--font-mono);">$10</span></div></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;display:grid;gap:12px;"><div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;"><div><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:6px;">Kill Switch</div><div style="font-size:12px;color:var(--text-muted);line-height:1.6;">This is the only writable governance control in WebUI v1. Use it to hard-stop dangerous capability execution without touching config files.</div></div><button style="padding:8px 14px;border-radius:6px;border:1px solid var(--border);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);font-family:var(--font-mono);font-size:11px;cursor:pointer;">ENABLE GLOBAL KILL</button></div><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(160px, 1fr));gap:12px;"><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Epoch</div><div style="font-family:var(--font-mono);color:var(--text-primary);">2</div></div><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Blocked Categories</div><div style="font-family:var(--font-mono);color:var(--text-primary);">1</div></div><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Blocked Capabilities</div><div style="font-family:var(--font-mono);color:var(--text-primary);">1</div></div></div></div><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:16px;"><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Unbound Profile Warnings</div><div style="font-size:11px;color:var(--text-secondary);line-height:1.8;"><div>Secret Warnings: <span style="color:var(--text-primary);font-family:var(--font-mono);">2</span></div><div>Sandbox Warnings: <span style="color:var(--text-primary);font-family:var(--font-mono);">3</span></div></div><div style="margin-top:10px;font-size:11px;color:var(--text-muted);line-height:1.7;"><div>Secret Coverage: <span style="color:var(--text-primary);">http.write</span></div><div>Sandbox Coverage: <span style="color:var(--text-primary);">exec.system</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Identity Defaults</div><div style="font-size:11px;color:var(--text-secondary);line-height:1.8;"><div>Interactive: <span style="color:var(--text-primary);font-family:var(--font-mono);">service_account</span></div><div>Automation: <span style="color:var(--text-primary);font-family:var(--font-mono);">instance_identity</span></div><div>Capability Overrides: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div></div></div></div><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:16px;"><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Secret Profiles</div><div style="padding:10px 0;border-top:1px solid var(--border);"><div style="display:flex;justify-content:space-between;gap:8px;align-items:center;margin-bottom:4px;"><div style="font-family:var(--font-mono);color:var(--text-primary);overflow-wrap:anywhere;">ops-http</div><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(45, 212, 191, 0.28);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);">headers</span></div><div style="font-size:11px;color:var(--text-secondary);line-height:1.6;"><div>Fields: 2</div><div>Bound Capabilities: 1</div></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Sandbox Profiles</div><div style="padding:10px 0;border-top:1px solid var(--border);"><div style="font-family:var(--font-mono);color:var(--text-primary);margin-bottom:4px;overflow-wrap:anywhere;">runtime-default</div><div style="font-size:11px;color:var(--text-secondary);line-height:1.6;"><div>Bound Capabilities: 1</div><div>Allowed Domains: api.example.com</div><div>Allowed Paths: /workspace</div><div>Blocked Commands: rm -rf</div></div></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Recent Audit Samples</div><div style="padding:10px 0;border-top:none;"><div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:4px;"><div style="font-family:var(--font-mono);color:var(--text-primary);overflow-wrap:anywhere;">exec.system</div><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(45, 212, 191, 0.28);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);">ok</span></div><div style="font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Actor: <span style="color:var(--text-primary);">instance:test3</span></div><div>Tool: <span style="color:var(--text-primary);">exec</span></div><div>Profiles: <span style="color:var(--text-primary);">— / runtime-default</span></div><div>Warnings: <span style="color:var(--text-primary);">unbound_secret_profile</span></div></div></div></div></div>"`;
