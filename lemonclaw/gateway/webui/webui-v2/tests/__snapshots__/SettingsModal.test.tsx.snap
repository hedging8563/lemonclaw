exports[`operator settings editors > renders HTTP auth profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">Saved Request Headers</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Save reusable request headers here. Leave masked values unchanged if you do not want to rotate a secret.</div></div><div style="margin-bottom:12px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;overflow:hidden;"><div style="display:flex;align-items:stretch;justify-content:space-between;gap:8px;"><button type="button" aria-expanded="false" style="flex:1;min-width:0px;display:flex;align-items:center;justify-content:space-between;gap:8px;padding:12px 16px;background:transparent;border:none;cursor:pointer;text-align:left;"><div style="display:flex;align-items:center;gap:8px;min-width:0px;"><span style="color:var(--text-primary);font-family:var(--font-mono);font-size:13px;font-weight:bold;overflow-wrap:anywhere;">support_api</span><span style="font-size:10px;padding:2px 6px;border-radius:3px;font-family:var(--font-mono);background:rgba(100,149,237,0.15);color:cornflowerblue;border:1px solid rgba(100,149,237,0.3);">2 headers</span></div><span style="color:var(--text-muted);font-size:12px;flex-shrink:0;">▼</span></button><button type="button" style="align-self:center;background:none;border:none;color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete profile" title="Delete profile">×</button></div></div><button type="button" style="width:100%;padding:10px;background:var(--bg-secondary);border:1px dashed var(--border);border-radius:6px;color:var(--text-muted);cursor:pointer;font-family:var(--font-mono);font-size:12px;">+ Add saved headers</button></div>"`;

exports[`operator settings editors > renders PostgreSQL profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">PostgreSQL Connections</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Save PostgreSQL read-only connections here. Leave masked passwords unchanged unless you want to rotate them.</div></div><div style="margin-bottom:12px;"><div style="margin-bottom:12px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;overflow:hidden;"><div style="display:flex;align-items:stretch;justify-content:space-between;gap:8px;"><button type="button" aria-expanded="false" style="flex:1;min-width:0px;display:flex;align-items:center;justify-content:space-between;gap:8px;padding:12px 16px;background:transparent;border:none;cursor:pointer;text-align:left;"><div style="display:flex;align-items:center;gap:8px;min-width:0px;"><span style="color:var(--text-primary);font-family:var(--font-mono);font-size:13px;font-weight:bold;overflow-wrap:anywhere;">analytics_ro</span><span style="font-size:10px;padding:2px 6px;border-radius:3px;font-family:var(--font-mono);background:rgba(76,175,80,0.15);color:var(--success);border:1px solid rgba(76,175,80,0.3);">db.example.internal</span><span style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">analytics</span></div><span style="color:var(--text-muted);font-size:12px;flex-shrink:0;">▼</span></button><button type="button" style="align-self:center;background:none;border:none;color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete connection" title="Delete connection">×</button></div></div></div><div style="display:flex;gap:8px;flex-wrap:nowrap;"><label for="postgres-profile-name" style="position:absolute;width:1px;height:1px;padding:0px;margin:-1px;overflow:hidden;clip:rect(0, 0, 0, 0);white-space:nowrap;border:0px;">Connection name (for example: analytics_ro)</label><input id="postgres-profile-name" name="postgres_profile_name" aria-label="Connection name (for example: analytics_ro)" style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value placeholder="Connection name (for example: analytics_ro)"/><button type="button" style="padding:8px 16px;background:var(--accent);border:none;border-radius:4px;color:#fff;cursor:pointer;font-family:var(--font-mono);font-size:12px;white-space:nowrap;width:auto;">Add connection</button></div></div>"`;

exports[`operator settings editors > renders SQLite profiles editor 1`] = `"<div style="margin-bottom:12px;"><div style="margin-bottom:10px;padding:12px;border-radius:6px;background:var(--bg-primary);border:1px solid var(--border);"><div style="font-size:12px;color:var(--text-primary);font-family:var(--font-mono);margin-bottom:4px;">SQLite Connections</div><div style="font-size:11px;color:var(--text-muted);line-height:1.6;">Give each SQLite file a friendly name so the bot can open it safely.</div></div><div style="margin-bottom:12px;"><div style="display:grid;grid-template-columns:minmax(140px, 0.8fr) minmax(0, 1.2fr) auto;gap:8px;align-items:start;margin-bottom:10px;"><div><label style="display:block;font-size:11px;color:var(--text-secondary);margin-bottom:4px;font-family:var(--font-mono);">Connection name</label><input style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value="local_cache" placeholder="Connection name (for example: local_cache)"/></div><div><label style="display:block;font-size:11px;color:var(--text-secondary);margin-bottom:4px;font-family:var(--font-mono);">SQLite file path</label><input style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value="/var/lib/lemonclaw/cache.db" placeholder="/var/lib/lemonclaw/app.db"/></div><div style="padding-top:22px;"><button type="button" style="align-self:center;background:none;border:1px solid var(--border);color:var(--error);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:4px;line-height:1;" aria-label="Delete connection" title="Delete connection">×</button></div></div></div><div style="display:flex;gap:8px;flex-wrap:nowrap;"><label for="sqlite-profile-name" style="position:absolute;width:1px;height:1px;padding:0px;margin:-1px;overflow:hidden;clip:rect(0, 0, 0, 0);white-space:nowrap;border:0px;">Connection name (for example: local_cache)</label><input id="sqlite-profile-name" name="sqlite_profile_name" aria-label="Connection name (for example: local_cache)" style="width:100%;background:var(--bg-primary);border:1px solid var(--border);color:var(--text-primary);padding:8px 10px;border-radius:4px;font-family:var(--font-mono);font-size:12px;outline:none;box-sizing:border-box;" type="text" value placeholder="Connection name (for example: local_cache)"/><button type="button" style="padding:8px 16px;background:var(--accent);border:none;border-radius:4px;color:#fff;cursor:pointer;font-family:var(--font-mono);font-size:12px;white-space:nowrap;width:auto;">Add connection</button></div></div>"`;

exports[`operator settings editors > renders governance overview tab 1`] = `"<div style="display:flex;flex-direction:column;gap:16px;"><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));gap:12px;"><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Safety status</div><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;"><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(45, 212, 191, 0.28);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);">Enabled</span><span style="display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:3px 10px;font-family:var(--font-mono);font-size:11px;border:1px solid;border-color:rgba(148, 163, 184, 0.24);background:rgba(148, 163, 184, 0.10);color:var(--text-muted);">Emergency stop off</span></div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Default safety level: <span style="color:var(--text-primary);font-family:var(--font-mono);">L1</span></div><div>Approval token time: <span style="color:var(--text-primary);font-family:var(--font-mono);">900s</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Protected Actions</div><div style="font-family:var(--font-mono);font-size:18px;color:var(--accent);font-weight:bold;">12</div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>On: <span style="color:var(--text-primary);font-family:var(--font-mono);">11</span></div><div>Off: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Saved Rules</div><div style="font-family:var(--font-mono);font-size:18px;color:var(--accent);font-weight:bold;">2</div><div style="margin-top:10px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Secrets: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div><div>Limits: <span style="color:var(--text-primary);font-family:var(--font-mono);">1</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-size:11px;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:8px;">Budget Limits</div><div style="margin-top:2px;font-size:11px;color:var(--text-secondary);line-height:1.7;"><div>Per task: <span style="color:var(--text-primary);font-family:var(--font-mono);">$2.5</span></div><div>Per day: <span style="color:var(--text-primary);font-family:var(--font-mono);">$50</span></div><div>Team per day: <span style="color:var(--text-primary);font-family:var(--font-mono);">$10</span></div></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;display:grid;gap:12px;"><div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;"><div><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:6px;">Emergency Stop</div><div style="font-size:12px;color:var(--text-muted);line-height:1.6;">This is the only safety control you can change here. Turn it on to immediately block high-risk actions.</div></div><button style="padding:8px 14px;border-radius:6px;border:1px solid var(--border);background:rgba(45, 212, 191, 0.10);color:var(--teal, #2dd4bf);font-family:var(--font-mono);font-size:11px;cursor:pointer;">TURN ON EMERGENCY STOP</button></div><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(160px, 1fr));gap:12px;"><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Version</div><div style="font-family:var(--font-mono);color:var(--text-primary);">2</div></div><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Blocked groups</div><div style="font-family:var(--font-mono);color:var(--text-primary);">1</div></div><div><div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-family:var(--font-mono);">Blocked actions</div><div style="font-family:var(--font-mono);color:var(--text-primary);">1</div></div></div></div><div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:16px;"><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Missing Rule Bindings</div><div style="font-size:11px;color:var(--text-secondary);line-height:1.8;"><div>Missing secret rules: <span style="color:var(--text-primary);font-family:var(--font-mono);">2</span></div><div>Missing limit rules: <span style="color:var(--text-primary);font-family:var(--font-mono);">3</span></div></div><div style="margin-top:10px;font-size:11px;color:var(--text-muted);line-height:1.7;"><div>Secrets coverage: <span style="color:var(--text-primary);">http write</span></div><div>Limits coverage: <span style="color:var(--text-primary);">exec system</span></div></div></div><div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:8px;padding:16px;"><div style="font-family:var(--font-mono);font-size:13px;color:var(--accent);margin-bottom:10px;">Who actions run as</div><div style="font-size:11px;color:var(--text-secondary);line-height:1.8;"><div