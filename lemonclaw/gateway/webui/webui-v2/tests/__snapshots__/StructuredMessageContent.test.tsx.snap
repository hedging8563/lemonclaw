exports[`StructuredMessageContent > renders audio player for audio and voice markers 1`] = `"<div style="display:flex;flex-direction:column;gap:4px;"><div style="margin:8px 0;border:1px solid var(--border);border-radius:8px;background:linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);padding:12px 14px;box-shadow:0 6px 18px rgba(0,0,0,0.16);"><div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;"><div style="display:inline-flex;align-items:center;gap:6px;padding:3px 8px;border-radius:999px;background:rgba(168,85,247,0.12);color:var(--purple);border:1px solid rgba(168,85,247,0.28);font-family:var(--font-mono);font-size:10px;letter-spacing:0.04em;"><span>🎤</span><span>VOICE</span></div><div style="display:flex;gap:8px;flex-wrap:wrap;"><a href="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fnote.ogg" target="_blank" rel="noopener noreferrer" style="font-size:10px;color:var(--accent);text-decoration:none;font-family:var(--font-mono);padding:3px 8px;border-radius:999px;border:1px solid var(--border);background:var(--bg-primary);">OPEN</a><a href="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fnote.ogg" download="note.ogg" style="font-size:10px;color:var(--teal);text-decoration:none;font-family:var(--font-mono);padding:3px 8px;border-radius:999px;border:1px solid var(--border);background:var(--bg-primary);">DOWNLOAD</a></div></div><div style="font-size:13px;color:var(--text-primary);margin-bottom:8px;word-break:break-word;font-weight:600;">note.ogg</div><audio controls preload="none" src="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fnote.ogg" style="display:block;width:100%;margin-bottom:8px;"></audio><div style="font-family:var(--font-mono);font-size:11px;color:var(--text-secondary);word-break:break-all;">/home/lemonclaw/.lemonclaw/media/note.ogg</div></div></div>"`;

exports[`StructuredMessageContent > renders image preview and links 1`] = `"<div style="display:flex;flex-direction:column;gap:4px;"><div style="margin:8px 0;border:1px solid var(--border);border-radius:8px;background:linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);padding:12px 14px;box-shadow:0 6px 18px rgba(0,0,0,0.16);"><div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;"><div style="display:inline-flex;align-items:center;gap:6px;padding:3px 8px;border-radius:999px;background:rgba(100,149,237,0.12);color:cornflowerblue;border:1px solid rgba(100,149,237,0.28);font-family:var(--font-mono);font-size:10px;letter-spacing:0.04em;"><span>🖼️</span><span>IMAGE</span></div><div style="display:flex;gap:8px;flex-wrap:wrap;"><a href="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fdemo.jpg" target="_blank" rel="noopener noreferrer" style="font-size:10px;color:var(--accent);text-decoration:none;font-family:var(--font-mono);padding:3px 8px;border-radius:999px;border:1px solid var(--border);background:var(--bg-primary);">OPEN</a><a href="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fdemo.jpg" download="demo.jpg" style="font-size:10px;color:var(--teal);text-decoration:none;font-family:var(--font-mono);padding:3px 8px;border-radius:999px;border:1px solid var(--border);background:var(--bg-primary);">DOWNLOAD</a></div></div><div style="font-size:13px;color:var(--text-primary);margin-bottom:8px;word-break:break-word;font-weight:600;">demo.jpg</div><button type="button" style="display:block;margin-bottom:8px;width:100%;padding:0px;border:none;background:transparent;cursor:zoom-in;" aria-label="Open image preview"><img src="/api/media?path=%2Fhome%2Flemonclaw%2F.lemonclaw%2Fmedia%2Fdemo.jpg" alt="demo.jpg" style="display:block;width:100%;max-height:240px;object-fit:contain;border-radius:6px;border:1px solid var(--border);background:var(--bg-primary);" loading="lazy"/></button><div style="font-family:var(--font-mono);font-size:11px;color:var(--text-secondary);word-break:break-all;">/home/lemonclaw/.lemonclaw/media/demo.jpg</div></div></div>"`;

exports[`StructuredMessageContent > renders runtime context and transcription blocks separately 1`] = `
